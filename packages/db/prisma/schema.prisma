// Prisma schema — Candidate Portal ATS
// Mirrors docs/specification/db-schema.md (PostgreSQL DDL).
//
// Location: packages/db/prisma/schema.prisma (shared via @ats-platform/db).
// From repo root: npm run db:migrate
// From packages/db: npx prisma migrate dev
//
// Prisma 7+ moved DATABASE_URL to prisma.config.ts — see §9 in db-schema.md and
// https://www.prisma.io/docs/orm/reference/prisma-config-reference
//
// Notes (see db-schema.md §5 + §9):
// - GIN index idx_postings_fulltext: add via raw SQL migration (not in this file).
// - Partial indexes in §5 DDL (idx_postings_remote, idx_postings_featured, idx_candidates_provider):
//   Prisma cannot declare WHERE clauses here; indexes below use default names and are full B-tree.
//   Replace with partial definitions from §5 in a follow-up migration if you need parity.
// - @@unique([email]) on candidates is case-sensitive; §5 uses LOWER(email) — adjust with raw SQL if required.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums (replace SQL CHECK constraints) ───

enum JobPostingStatus {
  draft
  published
  closed
  archived
}

enum SalaryPeriod {
  annual
  monthly
}

enum QualificationType {
  required
  preferred
}

enum ApplicationStatus {
  submitted
  under_review
  shortlisted
  interview
  interview_scheduled
  interview_completed
  offered
  hired
  rejected
  withdrawn
}

enum CandidateCoverLetterMode {
  file
  text
}

enum UserRole {
  admin
  recruiter
  hiring_manager
}

enum CandidateAccountStatus {
  pending_verification
  active
  locked
  disabled
}

enum CandidateAuthProviderType {
  google
  linkedin
}

enum CandidateCvParseStatus {
  draft
  confirmed
}

// ─── Lookup tables ───

model Company {
  id         Int      @id @default(autoincrement())
  name       String   @unique @db.VarChar(200)
  logoUrl    String?  @map("logo_url") @db.VarChar(500)
  websiteUrl String?  @map("website_url") @db.VarChar(500)
  isActive   Boolean  @default(true) @map("is_active")
  sortOrder  Int      @default(0) @map("sort_order") @db.SmallInt
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  jobPostings JobPosting[]

  @@map("companies")
}

model Department {
  id         Int      @id @default(autoincrement())
  name       String   @unique @db.VarChar(100)
  slug       String   @unique @db.VarChar(100)
  isActive   Boolean  @default(true) @map("is_active")
  sortOrder  Int      @default(0) @map("sort_order") @db.SmallInt
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  jobPostings JobPosting[]

  @@map("departments")
}

model Location {
  id        Int      @id @default(autoincrement())
  city      String   @db.VarChar(100)
  country   String   @db.VarChar(100)
  slug      String   @unique @db.VarChar(100)
  isActive  Boolean  @default(true) @map("is_active")
  sortOrder Int      @default(0) @map("sort_order") @db.SmallInt
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  jobPostings JobPosting[]

  @@map("locations")
}

model EmploymentType {
  id        Int     @id @default(autoincrement())
  name      String  @unique @db.VarChar(50)
  slug      String  @unique @db.VarChar(50)
  isActive  Boolean @default(true) @map("is_active")
  sortOrder Int     @default(0) @map("sort_order") @db.SmallInt

  jobPostings JobPosting[]

  @@map("employment_types")
}

model ExperienceLevel {
  id        Int     @id @default(autoincrement())
  name      String  @unique @db.VarChar(50)
  slug      String  @unique @db.VarChar(50)
  minYears  Int     @default(0) @map("min_years") @db.SmallInt
  isActive  Boolean @default(true) @map("is_active")
  sortOrder Int     @default(0) @map("sort_order") @db.SmallInt

  jobPostings JobPosting[]

  @@map("experience_levels")
}

model Skill {
  id        Int      @id @default(autoincrement())
  name      String   @unique @db.VarChar(100)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  jobPostingSkills JobPostingSkill[]

  @@map("skills")
}

model Benefit {
  id          Int     @id @default(autoincrement())
  description String  @db.VarChar(255)
  isActive    Boolean @default(true) @map("is_active")
  sortOrder   Int     @default(0) @map("sort_order") @db.SmallInt

  jobPostingBenefits JobPostingBenefit[]

  @@map("benefits")
}

model Tag {
  id        Int     @id @default(autoincrement())
  name      String  @unique @db.VarChar(50)
  variant   String  @default("primary") @db.VarChar(20)
  isActive  Boolean @default(true) @map("is_active")
  sortOrder Int     @default(0) @map("sort_order") @db.SmallInt

  jobPostingTags JobPostingTag[]

  @@map("tags")
}

// ─── Admin users ───

model User {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email        String   @unique @db.VarChar(255)
  name         String   @db.VarChar(200)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  role         UserRole @default(recruiter)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  createdJobPostings       JobPosting[]              @relation("JobPostingCreator")
  applicationStatusChanges ApplicationStatusEvent[]
  scheduledInterviews      ApplicationInterview[]    @relation("InterviewScheduledBy")

  @@map("users")
}

// ─── Core posting ───

model JobPosting {
  id                 String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title              String           @db.VarChar(200)
  slug               String           @unique @db.VarChar(220)
  companyId          Int              @map("company_id")
  departmentId       Int              @map("department_id")
  locationId         Int              @map("location_id")
  employmentTypeId   Int              @map("employment_type_id")
  experienceLevelId  Int              @map("experience_level_id")
  summary            String           @db.VarChar(500)
  overview           String?          @db.Text
  roleSummary        String?          @map("role_summary") @db.Text
  applicationInfo    String?          @map("application_info") @db.Text
  salaryMin          Decimal?         @map("salary_min") @db.Decimal(12, 2)
  salaryMax          Decimal?         @map("salary_max") @db.Decimal(12, 2)
  salaryCurrency     String?          @map("salary_currency") @db.Char(3)
  salaryPeriod       SalaryPeriod     @default(annual) @map("salary_period")
  isSalaryVisible    Boolean          @default(false) @map("is_salary_visible")
  isRemote           Boolean          @default(false) @map("is_remote")
  isFeatured         Boolean          @default(false) @map("is_featured")
  status             JobPostingStatus @default(draft)
  postedAt           DateTime?        @map("posted_at") @db.Timestamptz(6)
  expiresAt          DateTime?        @map("expires_at") @db.Timestamptz(6)
  createdAt          DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime         @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdById        String?          @map("created_by") @db.Uuid
  bannerImageUrl     String?          @map("banner_image_url") @db.VarChar(500)
  bannerImageAlt     String?          @map("banner_image_alt") @db.VarChar(255)

  company          Company            @relation(fields: [companyId], references: [id])
  department       Department         @relation(fields: [departmentId], references: [id])
  location         Location           @relation(fields: [locationId], references: [id])
  employmentType   EmploymentType     @relation(fields: [employmentTypeId], references: [id])
  experienceLevel  ExperienceLevel    @relation(fields: [experienceLevelId], references: [id])
  creator          User?              @relation("JobPostingCreator", fields: [createdById], references: [id])

  responsibilities   JobResponsibility[]
  qualifications     JobQualification[]
  jobPostingSkills   JobPostingSkill[]
  jobPostingBenefits JobPostingBenefit[]
  jobPostingTags     JobPostingTag[]
  bookmarks          Bookmark[]
  applications       Application[]

  @@index([status, postedAt(sort: Desc)], map: "idx_postings_status_posted")
  @@index([companyId], map: "idx_postings_company")
  @@index([departmentId], map: "idx_postings_department")
  @@index([locationId], map: "idx_postings_location")
  @@index([employmentTypeId], map: "idx_postings_emp_type")
  @@index([experienceLevelId], map: "idx_postings_experience")
  // §5 DDL uses partial indexes named idx_postings_remote / idx_postings_featured — Prisma emits full B-tree here
  @@index([isRemote])
  @@index([isFeatured])
  @@index([slug], map: "idx_postings_slug")
  @@map("job_postings")
}

model JobResponsibility {
  id            Int    @id @default(autoincrement())
  jobPostingId  String @map("job_posting_id") @db.Uuid
  description   String @db.Text
  sortOrder     Int    @default(0) @map("sort_order") @db.SmallInt

  jobPosting JobPosting @relation(fields: [jobPostingId], references: [id], onDelete: Cascade)

  @@map("job_responsibilities")
}

model JobQualification {
  id           Int               @id @default(autoincrement())
  jobPostingId String            @map("job_posting_id") @db.Uuid
  description  String            @db.Text
  type         QualificationType @default(required)
  sortOrder    Int               @default(0) @map("sort_order") @db.SmallInt

  jobPosting JobPosting @relation(fields: [jobPostingId], references: [id], onDelete: Cascade)

  @@map("job_qualifications")
}

model JobPostingSkill {
  jobPostingId String @map("job_posting_id") @db.Uuid
  skillId      Int    @map("skill_id")
  sortOrder    Int    @default(0) @map("sort_order") @db.SmallInt

  jobPosting JobPosting @relation(fields: [jobPostingId], references: [id], onDelete: Cascade)
  skill      Skill      @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([jobPostingId, skillId])
  @@map("job_posting_skills")
}

model JobPostingBenefit {
  jobPostingId String @map("job_posting_id") @db.Uuid
  benefitId    Int    @map("benefit_id")
  sortOrder    Int    @default(0) @map("sort_order") @db.SmallInt

  jobPosting JobPosting @relation(fields: [jobPostingId], references: [id], onDelete: Cascade)
  benefit    Benefit    @relation(fields: [benefitId], references: [id], onDelete: Cascade)

  @@id([jobPostingId, benefitId])
  @@map("job_posting_benefits")
}

model JobPostingTag {
  jobPostingId String @map("job_posting_id") @db.Uuid
  tagId        Int    @map("tag_id")
  sortOrder    Int    @default(0) @map("sort_order") @db.SmallInt

  jobPosting JobPosting @relation(fields: [jobPostingId], references: [id], onDelete: Cascade)
  tag        Tag        @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([jobPostingId, tagId])
  @@map("job_posting_tags")
}

// ─── Candidate accounts, profiles & interactions ───

model CandidateAccount {
  id                  String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email               String                  @db.VarChar(255)
  emailNormalized     String                  @map("email_normalized") @db.VarChar(255)
  passwordHash        String?                 @map("password_hash") @db.VarChar(255)
  status              CandidateAccountStatus  @default(pending_verification)
  emailVerifiedAt     DateTime?               @map("email_verified_at") @db.Timestamptz(6)
  lastLoginAt         DateTime?               @map("last_login_at") @db.Timestamptz(6)
  failedLoginAttempts Int                     @default(0) @map("failed_login_attempts")
  lockedUntil         DateTime?               @map("locked_until") @db.Timestamptz(6)
  createdAt           DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime                @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  profile             CandidateProfile?
  authProviders       CandidateAuthProvider[]
  sessions            CandidateSession[]
  verificationTokens  CandidateVerificationToken[]
  passwordResetTokens CandidatePasswordResetToken[]
  bookmarks           Bookmark[]
  applications        Application[]
  cvParses            CandidateCvParse[]
  cvEducation         CandidateCvEducation[]
  cvExperience        CandidateCvExperience[]
  coverLetters        CandidateCoverLetter[]

  @@unique([email])
  @@unique([emailNormalized], map: "candidate_accounts_email_normalized_key")
  @@index([status], map: "idx_candidate_accounts_status")
  @@map("candidate_accounts")
}

model CandidateProfile {
  candidateAccountId String   @id @map("candidate_account_id") @db.Uuid
  firstName          String?  @map("first_name") @db.VarChar(100)
  lastName           String?  @map("last_name") @db.VarChar(100)
  avatarUrl          String?  @map("avatar_url") @db.VarChar(500)
  phone              String?  @db.VarChar(30)
  resumeUrl          String?  @map("resume_url") @db.VarChar(500)
  location           String?  @db.VarChar(200)
  currentTitle       String?  @map("current_title") @db.VarChar(200)
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  candidateAccount CandidateAccount @relation(fields: [candidateAccountId], references: [id], onDelete: Cascade)

  @@map("candidate_profiles")
}

model CandidateCvParse {
  id                 String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  candidateAccountId String                 @map("candidate_account_id") @db.Uuid
  originalFilename   String                 @map("original_filename") @db.VarChar(500)
  storedPath         String                 @map("stored_path") @db.VarChar(1000)
  mimeType           String                 @map("mime_type") @db.VarChar(100)
  extractedText      String?                @map("extracted_text") @db.Text
  parsedJson         Json?                  @map("parsed_json")
  status               CandidateCvParseStatus @default(draft)
  createdAt          DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime               @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  candidateAccount CandidateAccount @relation(fields: [candidateAccountId], references: [id], onDelete: Cascade)

  @@index([candidateAccountId], map: "idx_candidate_cv_parses_account")
  @@map("candidate_cv_parses")
}

model CandidateCvEducation {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  candidateAccountId String   @map("candidate_account_id") @db.Uuid
  qualification      String   @db.VarChar(400)
  institution        String   @db.VarChar(400)
  startDate          String?  @map("start_date") @db.VarChar(80)
  endDate            String?  @map("end_date") @db.VarChar(80)
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  candidateAccount CandidateAccount @relation(fields: [candidateAccountId], references: [id], onDelete: Cascade)

  @@index([candidateAccountId], map: "idx_candidate_cv_education_account")
  @@map("candidate_cv_educations")
}

model CandidateCvExperience {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  candidateAccountId String   @map("candidate_account_id") @db.Uuid
  company            String   @db.VarChar(300)
  role               String   @db.VarChar(300)
  startDate          String?  @map("start_date") @db.VarChar(80)
  endDate            String?  @map("end_date") @db.VarChar(80)
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  candidateAccount CandidateAccount @relation(fields: [candidateAccountId], references: [id], onDelete: Cascade)

  @@index([candidateAccountId], map: "idx_candidate_cv_experience_account")
  @@map("candidate_cv_experiences")
}

model CandidateAuthProvider {
  id                 String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  candidateAccountId String                    @map("candidate_account_id") @db.Uuid
  provider           CandidateAuthProviderType
  providerUserId     String                    @map("provider_user_id") @db.VarChar(255)
  createdAt          DateTime                  @default(now()) @map("created_at") @db.Timestamptz(6)

  candidateAccount CandidateAccount @relation(fields: [candidateAccountId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId], map: "candidate_auth_providers_provider_provider_user_id_key")
  @@index([candidateAccountId], map: "idx_candidate_auth_providers_account")
  @@map("candidate_auth_providers")
}

model CandidateSession {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  candidateAccountId String  @map("candidate_account_id") @db.Uuid
  refreshTokenHash String    @map("refresh_token_hash") @db.VarChar(255)
  userAgent        String?   @map("user_agent") @db.VarChar(512)
  ipAddress        String?   @map("ip_address") @db.VarChar(64)
  expiresAt        DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt        DateTime? @map("revoked_at") @db.Timestamptz(6)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  candidateAccount CandidateAccount @relation(fields: [candidateAccountId], references: [id], onDelete: Cascade)

  @@index([candidateAccountId, expiresAt(sort: Desc)], map: "idx_candidate_sessions_account_expires")
  @@map("candidate_sessions")
}

model CandidateVerificationToken {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  candidateAccountId String    @map("candidate_account_id") @db.Uuid
  tokenHash          String    @map("token_hash") @db.VarChar(255)
  expiresAt          DateTime  @map("expires_at") @db.Timestamptz(6)
  usedAt             DateTime? @map("used_at") @db.Timestamptz(6)
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  candidateAccount CandidateAccount @relation(fields: [candidateAccountId], references: [id], onDelete: Cascade)

  @@index([candidateAccountId, expiresAt(sort: Desc)], map: "idx_candidate_verification_tokens_account")
  @@map("candidate_verification_tokens")
}

model CandidatePasswordResetToken {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  candidateAccountId String    @map("candidate_account_id") @db.Uuid
  tokenHash          String    @map("token_hash") @db.VarChar(255)
  expiresAt          DateTime  @map("expires_at") @db.Timestamptz(6)
  usedAt             DateTime? @map("used_at") @db.Timestamptz(6)
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  candidateAccount CandidateAccount @relation(fields: [candidateAccountId], references: [id], onDelete: Cascade)

  @@index([candidateAccountId, expiresAt(sort: Desc)], map: "idx_candidate_password_reset_tokens_account")
  @@map("candidate_password_reset_tokens")
}

model Bookmark {
  candidateAccountId String   @map("candidate_account_id") @db.Uuid
  jobPostingId       String   @map("job_posting_id") @db.Uuid
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  candidateAccount CandidateAccount @relation(fields: [candidateAccountId], references: [id], onDelete: Cascade)
  jobPosting       JobPosting       @relation(fields: [jobPostingId], references: [id], onDelete: Cascade)

  @@id([candidateAccountId, jobPostingId])
  @@map("bookmarks")
}

model Application {
  id                 String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  candidateAccountId String            @map("candidate_account_id") @db.Uuid
  jobPostingId       String            @map("job_posting_id") @db.Uuid
  status             ApplicationStatus @default(submitted)
  coverLetter        String?           @map("cover_letter") @db.Text
  resumeUrl          String?           @map("resume_url") @db.VarChar(500)
  experienceYears       Int?       @map("experience_years")
  experienceMonths      Int?       @map("experience_months")
  hasDomainExperience   Boolean?   @map("has_domain_experience")
  noticePeriods         String?    @map("notice_periods") @db.Text
  salaryExpectationAnnual Decimal? @map("salary_expectation_annual") @db.Decimal(12, 2)
  willingToRelocate     Boolean?   @map("willing_to_relocate")
  isLegallyAuthorizedToWork Boolean? @map("is_legally_authorized_to_work")
  workModePreference    String?    @map("work_mode_preference") @db.VarChar(50)
  shortMotivation       String?    @map("short_motivation") @db.Text
  relevanceScore        Int?       @map("relevance_score") @db.SmallInt
  relevanceBreakdown    String?    @map("relevance_breakdown") @db.Text
  relevanceScoredAt     DateTime?  @map("relevance_scored_at") @db.Timestamptz(6)
  relevanceInputHash    String?    @map("relevance_input_hash") @db.VarChar(64)
  appliedAt          DateTime          @default(now()) @map("applied_at") @db.Timestamptz(6)
  updatedAt          DateTime          @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  candidateAccount CandidateAccount         @relation(fields: [candidateAccountId], references: [id])
  jobPosting       JobPosting               @relation(fields: [jobPostingId], references: [id])
  statusEvents     ApplicationStatusEvent[]
  interviews       ApplicationInterview[]

  @@unique([candidateAccountId, jobPostingId], map: "idx_applications_unique")
  @@index([status], map: "idx_applications_status")
  @@index([jobPostingId, appliedAt(sort: Desc)], map: "idx_applications_job")
  @@map("applications")
}

model ApplicationStatusEvent {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  applicationId    String             @map("application_id") @db.Uuid
  fromStatus       ApplicationStatus? @map("from_status")
  toStatus         ApplicationStatus  @map("to_status")
  changedAt        DateTime           @default(now()) @map("changed_at") @db.Timestamptz(6)
  changedByStaffId String?            @map("changed_by_staff_id") @db.Uuid

  application    Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  changedByStaff User?       @relation(fields: [changedByStaffId], references: [id], onDelete: SetNull)

  @@index([applicationId, changedAt(sort: Desc)], map: "idx_application_status_events_app_time")
  @@map("application_status_events")
}

model ApplicationInterview {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  applicationId        String   @map("application_id") @db.Uuid
  startsAt             DateTime @map("starts_at") @db.Timestamptz(6)
  endsAt               DateTime @map("ends_at") @db.Timestamptz(6)
  notifyCandidateEmail Boolean  @default(true) @map("notify_candidate_email")
  notificationSentAt   DateTime? @map("notification_sent_at") @db.Timestamptz(6)
  scheduledByStaffId   String?  @map("scheduled_by_staff_id") @db.Uuid
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  application      Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  scheduledByStaff User?       @relation("InterviewScheduledBy", fields: [scheduledByStaffId], references: [id], onDelete: SetNull)

  @@index([applicationId, startsAt(sort: Desc)], map: "idx_application_interviews_app_time")
  @@map("application_interviews")
}

model CandidateCoverLetter {
  id                 String                  @id @db.Uuid
  candidateAccountId String                  @map("candidate_account_id") @db.Uuid
  mode               CandidateCoverLetterMode
  body               String?                 @db.Text
  fileUrl            String?                 @map("file_url") @db.VarChar(500)
  fileName           String?                 @map("file_name") @db.VarChar(255)
  createdAt          DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)

  candidateAccount CandidateAccount @relation(fields: [candidateAccountId], references: [id], onDelete: Cascade)

  @@index([candidateAccountId, createdAt(sort: Desc)], map: "idx_candidate_cover_letters_candidate_created")
  @@map("candidate_cover_letters")
}
